# ─────────────────────────────────────────────────────────────────────────────
# Rentage API — Environment Variables Reference
# Copy to apps/api/.env and fill in the values.
# Never commit the real .env file (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/rentage

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── COOKIES ──────────────────────────────────────────────────────────────────
COOKIE_SECRET=your-cookie-secret-min-32-chars

# ─── APP URLS ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NODE_ENV=development
PORT=4000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Extra origins the API will accept (comma-separated).
# Example: ALLOWED_ORIGINS=http://192.168.1.42:3000,https://staging.example.com
ALLOWED_ORIGINS=

# Hostnames (no protocol, no port) allowed to load /_next/* assets in dev.
# Set this in apps/web/.env.local — not here. Example: 192.168.1.42
ALLOWED_DEV_ORIGINS=

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ─── CLOUDINARY (file uploads) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── EMAIL — Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Rentage <no-reply@rentage.in>

# ─── SMS — MSG91 ──────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=RENTAG

# ─── WHATSAPP — Gupshup ───────────────────────────────────────────────────────
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE_NUMBER=

# ─── PUSH — Firebase (FCM) ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
# Paste the private key with literal \n — it will be unescaped at runtime
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── PAYMENTS — Razorpay ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── MAPS — Google ────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── QUEUE — Redis (optional; enables BullMQ notification jobs) ───────────────
# Leave empty to run notifications synchronously without a queue.
REDIS_URL=

